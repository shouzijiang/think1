<view class="game-tabbar-wrap">
  <view class="game-tabbar">
    <view class="tab-item {{selected===0?'active':''}}" data-index="0" data-path="/pages/index/index" bindtap="switchTab">
      <view class="tab-icon-wrap">
        <image class="tab-icon" src="{{selected===0?'/static/tabbar/tab-game-active.png':'/static/tabbar/tab-game.png'}}" mode="aspectFit" />
      </view>
      <text class="tab-text">游戏</text>
    </view>
    <view class="tab-item {{selected===1?'active':''}}" data-index="1" data-path="/pages/rank/rank" bindtap="switchTab">
      <view class="tab-icon-wrap">
        <image class="tab-icon" src="{{selected===1?'/static/tabbar/tab-rank-active.png':'/static/tabbar/tab-rank.png'}}" mode="aspectFit" />
      </view>
      <text class="tab-text">排行</text>
    </view>
    <view class="tab-item {{selected===2?'active':''}}" data-index="2" data-path="/pages/levels/levels" bindtap="switchTab">
      <view class="tab-icon-wrap">
        <image class="tab-icon" src="{{selected===2?'/static/tabbar/tab-levels-active.png':'/static/tabbar/tab-levels.png'}}" mode="aspectFit" />
      </view>
      <text class="tab-text">关卡</text>
    </view>
    <view class="tab-item {{selected===3?'active':''}}" data-index="3" data-path="/pages/mine/mine" bindtap="switchTab">
      <view class="tab-icon-wrap">
        <image class="tab-icon" src="{{selected===3?'/static/tabbar/tab-mine-active.png':'/static/tabbar/tab-mine.png'}}" mode="aspectFit" />
      </view>
      <text class="tab-text">我的</text>
    </view>
  </view>
</view>
